#!/bin/sh
# ga-bootstrap — first-boot orchestrator that brings up ga_manager.
#
# Runs once after `hassio-supervisor.service` is healthy. Performs the
# minimum bootstrap steps needed for ga_manager to take over and converge
# the rest of the system:
#
#   1. Wait until Supervisor responds.
#   2. Add the public `vibe_addons` add-on store (idempotent).
#   3. Write GHCR pull credentials into Supervisor's auth registry
#      (= unblocks pulling the private ga_manager addon image).
#   4. Install + start the `ga_manager` add-on.
#   5. Touch the marker file so this service is a no-op on future boots.
#
# Everything beyond this — DNS, watchdog, addon options, per-device
# secrets, bundle expectation, dashboard, etc. — is the responsibility
# of `ga_manager` converge. Keep ga-bootstrap tiny.
#
# Exit codes:
#   0 — bootstrap finished cleanly OR marker already present (no-op).
#   1 — Supervisor never came up within SUPERVISOR_WAIT_S seconds.
#   2 — Adding the vibe_addons store failed (network / supervisor error).
#   3 — Writing GHCR credentials failed.
#   4 — `ha addons install ga_manager` failed.
#
# Env overrides (read from /etc/ga/ga-bootstrap.conf if present, then
# from the environment — env wins):
#   MARKER                    default /mnt/data/.ga-bootstrapped
#   SUPERVISOR_WAIT_S         default 1200  (cold boot eMMC is slow)
#   SUPERVISOR_POLL_INTERVAL  default 5
#   GA_MANAGER_SLUG           default 99f1cad4_ga_manager
#   VIBE_STORE_URL            default https://github.com/greenautarky/vibe_addons
#   GHCR_CREDS_FILE           default /etc/ga/ghcr-creds.json
#                              {"ghcr.io":{"username":"…","password":"…"}}
#   HA_CORE_WAIT_S            default 600   (HA Core cold-start can be slow)
#   HA_CORE_POLL_INTERVAL     default 10
#   JQ_CLI                    default jq    (path / fallback for the json parser)
#
# Test seam: every external binary is invoked via a variable so the
# pytest harness can replace `ha` / `docker` with a shim on $PATH and
# `BG_DRY_RUN=1` short-circuits the marker write.
#
# Step 0a (auto_update=false) goes via the Supervisor API, not direct
# edit of updater.json — the OS-side ga-ha-init learned the hard way
# (KIB-SON-31 first boot 2026-05-27) that Supervisor rewrites
# updater.json on the next refresh, clobbering any jq-style direct edit.
# `ha supervisor options --auto-update=false` mutates Supervisor's
# in-memory state and persists. Order matters: run Step 0a *before*
# installing addons so even the first ga_manager addon install can't
# trigger an auto-update side effect.
#
# Step 6 (wait for HA Core ready) absorbs ga-ha-init's responsibilities
# so ga-bootstrap exits only once the device is fully reachable. The
# OS-side ga-ha-init.service is removed in the matching ha-operating-
# system PR.

set -eu

# --- config -----------------------------------------------------------
CONF=/etc/ga/ga-bootstrap.conf
if [ -f "$CONF" ]; then
  # shellcheck disable=SC1090  # runtime-resolved path is intentional
  . "$CONF"
fi

MARKER="${MARKER:-/mnt/data/.ga-bootstrapped}"
SUPERVISOR_WAIT_S="${SUPERVISOR_WAIT_S:-1200}"
SUPERVISOR_POLL_INTERVAL="${SUPERVISOR_POLL_INTERVAL:-5}"
HA_CORE_WAIT_S="${HA_CORE_WAIT_S:-600}"
HA_CORE_POLL_INTERVAL="${HA_CORE_POLL_INTERVAL:-10}"
GA_MANAGER_SLUG="${GA_MANAGER_SLUG:-99f1cad4_ga_manager}"
VIBE_STORE_URL="${VIBE_STORE_URL:-https://github.com/greenautarky/vibe_addons}"
GHCR_CREDS_FILE="${GHCR_CREDS_FILE:-/etc/ga/ghcr-creds.json}"
HA_CLI="${HA_CLI:-ha}"
JQ_CLI="${JQ_CLI:-jq}"
DRY_RUN="${BG_DRY_RUN:-0}"
# Exponential-backoff sequence for the two retry loops (store-add +
# addons-install). Space-separated pre-sleep seconds. Tests override
# this to short delays so the suite finishes in <30 s; production
# default is the field-validated 0/10/30/60/120/240 (~8 min budget).
BACKOFF_SEQUENCE="${BACKOFF_SEQUENCE:-0 10 30 60 120 240}"

log() { printf '[ga-bootstrap] %s\n' "$*"; }
fail() { log "ERROR: $1"; exit "${2:-1}"; }

# --- 0. marker check (idempotent) -------------------------------------
if [ -f "$MARKER" ]; then
  log "marker $MARKER present — bootstrap already completed, exiting 0"
  exit 0
fi

# --- 1. wait for supervisor -------------------------------------------
log "waiting for Supervisor (up to ${SUPERVISOR_WAIT_S}s)"
deadline=$(( $(date +%s) + SUPERVISOR_WAIT_S ))
sup_info=""
while :; do
  sup_info=$("$HA_CLI" supervisor info --raw-json 2>/dev/null || true)
  if printf '%s' "$sup_info" | grep -q '"result":"ok"'; then
    log "Supervisor ready"
    break
  fi
  if [ "$(date +%s)" -ge "$deadline" ]; then
    fail "Supervisor never reported ok within ${SUPERVISOR_WAIT_S}s" 1
  fi
  sleep "$SUPERVISOR_POLL_INTERVAL"
done

# --- 1a. disable Supervisor auto-update -------------------------------
# Why: fleet devices must not auto-update Supervisor — the rollout is
# operator-controlled via push-ota.sh + RAUC bundle promotion. Auto-update
# bypasses that and has caused incidents (incident_ga1_hang_2026_05_06 —
# Supervisor auto-updated hassio_cli mid-run and triggered an eMMC stall).
#
# Go via the Supervisor API even though we have jq — direct jq on
# /mnt/data/supervisor/updater.json silently fails: Supervisor caches
# auto_update in memory and rewrites the file on the next refresh,
# clobbering the edit (observed on KIB-SON-31, 2026-05-27). The CLI's
# `supervisor options --auto-update=false` mutates the in-memory state
# so the change actually sticks.
# Reuse the supervisor-info response we just captured in the wait loop
# above — one fewer API round-trip. NB: do NOT use jq's `// "missing"`
# here — `//` triggers on null OR false, so a correct
# `auto_update: false` reading would report "missing" and we'd re-issue
# the options call every boot. Read the raw bool with tostring instead;
# a genuinely missing field shows up as "null" and we treat that as
# "needs setting".
current_auto=$(printf '%s' "$sup_info" \
                  | "$JQ_CLI" -r '.data.auto_update | tostring' 2>/dev/null || echo null)
if [ "$current_auto" = "false" ]; then
  log "Supervisor auto_update=false (already set)"
else
  log "Supervisor auto_update was $current_auto — setting false via API"
  if ! "$HA_CLI" supervisor options --auto-update=false --no-progress >/dev/null 2>&1; then
    # NON-FATAL: if Supervisor's API rejects the call here, the device
    # is still usable and ga_manager converge step 8 will retry every
    # 30 s. We log a warning, do NOT bail — exiting non-zero here
    # would prevent the rest of bootstrap from running.
    log "WARN: Supervisor rejected auto-update=false — converge will retry"
  fi
fi

# --- 2. add vibe_addons store -----------------------------------------
# `ha store add` is a misleading API: it returns 0 once Supervisor accepts
# the addition into its config, but the actual `git clone` happens
# asynchronously in the background, and can fail with "invalid HEAD" or
# exit 128 within the first 1-2 minutes (Supervisor + git race on slow
# eMMC / cold network). A 0 exit code is NOT trust-worthy on its own.
#
# We therefore loop with an exponential-backoff (0/10/30/60/120/240 s
# pre-sleep, ~8 min total budget) AND verify after each call that the
# repo actually shows up in `ha store repositories --raw-json`.
#
# This pattern is identical to the rootfs ga-bootstrap retained until
# BOSv1.2.4 — proven against transient supervisor-git-clone races in the
# field. The build-test BS-RETRY-01/02 enforces both exist.

addon_repo_present() {
  # ha store repositories --raw-json lists configured repos under .data.
  # Compare source URLs with trailing-slash normalisation.
  "$HA_CLI" store repositories --no-progress --raw-json 2>/dev/null \
    | "$JQ_CLI" -e --arg url "$VIBE_STORE_URL" '
        (.data.repositories // .repositories // .data // [])
        | map((.source // "") | rtrimstr("/"))
        | any(. == ($url | rtrimstr("/")))
      ' >/dev/null 2>&1
}

log "adding vibe_addons store ($VIBE_STORE_URL) — with retry"
store_added=0
for pre_sleep in $BACKOFF_SEQUENCE; do
  if [ "$pre_sleep" -gt 0 ]; then
    log "waiting ${pre_sleep}s before retry..."
    "$HA_CLI" store reload --no-progress >/dev/null 2>&1 || true
    sleep "$pre_sleep"
  fi
  # Capture stderr+stdout so we can distinguish "already added" from
  # real failures. Exit code alone is insufficient — supervisor returns
  # non-zero for both "already added" and transient clone failure.
  store_log=$(mktemp -t ga-bootstrap-store.XXXXXX)
  "$HA_CLI" --no-progress store add "$VIBE_STORE_URL" >"$store_log" 2>&1 && rc=0 || rc=$?
  cat "$store_log"
  rm -f "$store_log"
  if [ "$rc" -eq 0 ] || grep -q -i 'already' "$store_log" 2>/dev/null; then
    if addon_repo_present; then
      log "vibe_addons store registered + verified"
      store_added=1
      "$HA_CLI" store reload --no-progress >/dev/null 2>&1 || true
      break
    fi
    log "store add returned ok but repo not yet visible — retrying"
  else
    log "store add returned $rc (likely transient supervisor-git race) — retrying"
  fi
done
[ "$store_added" -eq 1 ] || fail "vibe_addons store failed to register after 6 attempts (~8 min)" 2

# --- 3. write GHCR pull creds -----------------------------------------
# Without these, the private ga_manager addon image pull would 401.
# The PAT is delivered into /etc/ga/ghcr-creds.json at OS bake time;
# we POST it into Supervisor's registries API so subsequent pulls
# carry the auth header.
if [ ! -f "$GHCR_CREDS_FILE" ]; then
  fail "$GHCR_CREDS_FILE missing — provisioner did not deliver creds" 3
fi
log "registering GHCR credentials with Supervisor"
if ! "$HA_CLI" --raw-json --no-progress \
      docker registries -f "$GHCR_CREDS_FILE" >/dev/null 2>&1; then
  fail "Supervisor rejected GHCR creds" 3
fi

# --- 4. install + start ga_manager ------------------------------------
# `install` is idempotent — if already installed, Supervisor returns
# the "already installed" response which `ha` treats as exit 0 on
# recent versions. We follow with `start` which is also idempotent.
#
# Verify-after-install is required for the same reason as the store-add
# pattern above: Supervisor reports success once the install JOB is
# accepted, but the actual image pull + container create happens
# asynchronously. We check addons_installed() (= the addon's reported
# version is non-null) until it succeeds, with the same exp-backoff
# budget as store-add (= same kind of supervisor-side race).

addons_installed() {
  # ha addons info --raw-json reports a "version" KEY for every store-
  # known addon, valued null until the addon is actually installed.
  # Check the VALUE, not just key presence.
  _v=$("$HA_CLI" addons info "$1" --no-progress --raw-json 2>/dev/null \
        | "$JQ_CLI" -r '(.data.version // .version // empty)' 2>/dev/null)
  [ -n "${_v}" ] && [ "${_v}" != "null" ]
}

log "installing $GA_MANAGER_SLUG — with retry"
addon_ready=0
for pre_sleep in $BACKOFF_SEQUENCE; do
  if [ "$pre_sleep" -gt 0 ]; then
    log "waiting ${pre_sleep}s before retry..."
    sleep "$pre_sleep"
  fi
  "$HA_CLI" addons install "$GA_MANAGER_SLUG" >/dev/null 2>&1 || true
  if addons_installed "$GA_MANAGER_SLUG"; then
    log "$GA_MANAGER_SLUG installed + verified"
    addon_ready=1
    break
  fi
  log "addon not yet installed — retrying"
done
[ "$addon_ready" -eq 1 ] || fail "ga_manager install failed/un-verifiable after 6 attempts (~8 min)" 4

log "starting $GA_MANAGER_SLUG"
if ! "$HA_CLI" addons start "$GA_MANAGER_SLUG"; then
  fail "ga_manager start failed (slug=$GA_MANAGER_SLUG)" 4
fi

# --- 4a. wait for HA Core ready ---------------------------------------
# Absorbs ga-ha-init's wait. We want ga-bootstrap to exit only once
# the device is fully reachable end-to-end — that's the contract a
# fleet-manager status probe relies on. Best-effort: if Core never
# reports "running" within HA_CORE_WAIT_S we log + continue (do NOT
# fail). The marker still gets written so a later boot isn't blocked
# on this same wait — converge keeps an eye on Core health after that.
log "waiting for HA Core to report state=running (up to ${HA_CORE_WAIT_S}s)"
deadline=$(( $(date +%s) + HA_CORE_WAIT_S ))
while :; do
  state=$("$HA_CLI" core info --no-progress --raw-json 2>/dev/null \
            | "$JQ_CLI" -r '.data.state // ""' 2>/dev/null || true)
  if [ "$state" = "running" ]; then
    log "HA Core state=running"
    break
  fi
  if [ "$(date +%s)" -ge "$deadline" ]; then
    log "WARN: HA Core never reported running within ${HA_CORE_WAIT_S}s (last state=${state:-unknown}) — continuing"
    break
  fi
  sleep "$HA_CORE_POLL_INTERVAL"
done

# --- 5. touch marker --------------------------------------------------
if [ "$DRY_RUN" = "1" ]; then
  log "dry-run: skipping marker write"
  exit 0
fi
mkdir -p "$(dirname "$MARKER")"
: > "$MARKER"
chmod 0644 "$MARKER"
log "wrote marker $MARKER — bootstrap done"
